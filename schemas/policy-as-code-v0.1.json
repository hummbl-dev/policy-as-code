{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/hummbl-dev/policy-as-code/main/schemas/policy-as-code-v0.1.json",
  "title": "Policy-as-Code v0.1 Packet",
  "type": "object",
  "required": [
    "schemaVersion",
    "packetStatus",
    "policyManifest",
    "authority",
    "rules",
    "receiptRequirements"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "v0.1"
    },
    "packetStatus": {
      "type": "string",
      "enum": ["seed", "v0.1-draft", "validated-example", "v0.1-packet"]
    },
    "policyManifest": {
      "type": "object",
      "required": ["id", "title", "version", "scope"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9\\-]*/[a-z0-9][a-z0-9\\-]*$"
        },
        "title": {
          "type": "string"
        },
        "version": {
          "type": "integer",
          "minimum": 1
        },
        "scope": {
          "type": "string"
        },
        "description": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "authority": {
      "type": "object",
      "required": ["owner", "canActOnBehalfOf"],
      "properties": {
        "owner": {
          "type": "string"
        },
        "canActOnBehalfOf": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "condition", "outcome", "severity"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9\\-]+$"
          },
          "name": {
            "type": "string"
          },
          "condition": {
            "type": "string"
          },
          "outcome": {
            "type": "string",
            "enum": ["allow", "deny", "warn", "require-review"]
          },
          "severity": {
            "type": "string",
            "enum": ["low", "medium", "high", "critical"]
          },
          "exceptions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "evaluation": {
            "type": "string",
            "enum": ["automated", "manual", "hybrid"]
          }
        },
        "additionalProperties": false
      }
    },
    "exceptionPolicy": {
      "type": "object",
      "required": ["enabled", "requiresReceipt", "maxOpenDays"],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "requiresReceipt": {
          "type": "boolean"
        },
        "maxOpenDays": {
          "type": "integer",
          "minimum": 1
        },
        "owner": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "receiptRequirements": {
      "type": "object",
      "required": ["ruleSource", "evaluation", "exception", "review", "finalState"],
      "properties": {
        "ruleSource": {
          "type": "string"
        },
        "evaluation": {
          "type": "string"
        },
        "exception": {
          "type": "string"
        },
        "review": {
          "type": "string"
        },
        "finalState": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "adjacentRepos": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
